@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to TechStack Web App</h1>
    @* <h2 class="display-4">This is Tech Stack WebApp from TechStack Account.</h2> *@
    @* <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p> *@
    
    @if(User.Identity?.IsAuthenticated==true)
    {
        <div class="alert alert-success mt-4" role="alert">
            <h4 class="alert-heading">You're signed in!</h4>
            <p>Welcome, <strong>@User.Identity.Name</strong>! You can now accessthe Dashboard to view person</p>
            <hr>
            <p class="mb-0">
                <a class="btn btn-primary btn-lg" asp-controller="Dashboard" asp-action="Index">Go to Dashboard</a>
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info mt-4" role="alert">
            <h4 class="alert-heading">Please sign in</h4>
            <p>This application requires Azure Entra ID authentication. Click the "Sign in" button in the navigation bar to get started.</p>
            <hr>
            <p class="mb-0">
                <a class="btn btn-primary btn-lg" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignIn">Sign in with Microsoft</a>
            </p>
        </div>

    }

</div>
